        "properties": {
          "severity": { "type": "string", "enum": ["bug", "warning", "info"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "message": { "type": "string" }
        }
      }
    },
    "summary": { "type": "string" },
    "raw_response": { "type": "string" }
  }
}

{
  "type": "object",
  "required": ["verdict", "findings"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["OKAY", "REJECT"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "status", "detail"],
        "properties": {
          "criterion": {
            "type": "string",
            "enum": ["COMPLETENESS", "CORRECTNESS", "VERIFIABILITY", "ORDERING", "RISK"]
          },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL"]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeReviewVerificationResponse",
  "description": "Structured response from code review finding verification.",
  "type": "object",
  "required": ["verified_findings", "summary"],
  "additionalProperties": false,
  "properties": {
    "verified_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "verdict", "file", "line", "revised_message", "evidence"],
        "additionalProperties": false,
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": ["confirmed", "uncertain", "rejected"]
          },
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "revised_message": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    },
    "raw_response": {
      "type": "string"
    }
  }
}

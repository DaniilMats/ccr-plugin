{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRReviewerResultV1",
  "type": "object",
  "additionalProperties": true,
  "required": ["contract_version", "findings", "summary"],
  "properties": {
    "contract_version": { "const": "ccr.reviewer_result.v1" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "line", "message"],
        "properties": {
          "severity": { "enum": ["bug", "warning", "info"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "summary": { "type": "string" },
    "raw_response": { "type": "string" },
    "llm_invocation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "provider",
        "tokens",
        "duration_ms",
        "exit_code",
        "timed_out",
        "schema_valid",
        "schema_retries"
      ],
      "properties": {
        "provider": { "type": ["string", "null"], "minLength": 1 },
        "thread_id": { "type": ["string", "null"] },
        "tokens": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "exit_code": { "type": "integer" },
        "error": { "type": ["string", "null"] },
        "timed_out": { "type": "boolean" },
        "schema_valid": { "type": "boolean" },
        "schema_retries": { "type": "integer", "minimum": 0 },
        "schema_violations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

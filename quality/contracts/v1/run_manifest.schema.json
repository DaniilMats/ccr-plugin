{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRRunManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_id",
    "created_at",
    "base_dir",
    "run_dir",
    "manifest_file",
    "diff_file",
    "requirements_file",
    "route_input_file",
    "route_plan_file",
    "route_helper_err_file",
    "review_context_file",
    "static_analysis_file",
    "shuffled_diff_file",
    "requirements_prompt_pass1_file",
    "requirements_prompt_pass2_file",
    "verify_batch_dir",
    "comments_dir",
    "report_file",
    "contract_versions"
  ],
  "properties": {
    "contract_version": { "const": "ccr.run_manifest.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "base_dir": { "type": "string", "minLength": 1 },
    "run_dir": { "type": "string", "minLength": 1 },
    "manifest_file": { "type": "string", "minLength": 1 },
    "diff_file": { "type": "string", "minLength": 1 },
    "requirements_file": { "type": "string", "minLength": 1 },
    "route_input_file": { "type": "string", "minLength": 1 },
    "route_plan_file": { "type": "string", "minLength": 1 },
    "route_helper_err_file": { "type": "string", "minLength": 1 },
    "review_context_file": { "type": "string", "minLength": 1 },
    "static_analysis_file": { "type": "string", "minLength": 1 },
    "shuffled_diff_file": { "type": "string", "minLength": 1 },
    "requirements_prompt_pass1_file": { "type": "string", "minLength": 1 },
    "requirements_prompt_pass2_file": { "type": "string", "minLength": 1 },
    "verify_batch_dir": { "type": "string", "minLength": 1 },
    "comments_dir": { "type": "string", "minLength": 1 },
    "report_file": { "type": "string", "minLength": 1 },
    "contract_versions": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}

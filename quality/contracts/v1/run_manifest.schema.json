    "verifier_results_dir": { "type": "string", "minLength": 1 },
    "reviewers_file": { "type": "string", "minLength": 1 },
    "candidates_file": { "type": "string", "minLength": 1 },
    "verification_prepare_file": { "type": "string", "minLength": 1 },
    "verified_findings_file": { "type": "string", "minLength": 1 },
    "posting_approval_file": { "type": "string", "minLength": 1 },
    "posting_manifest_file": { "type": "string", "minLength": 1 },
    "posting_results_file": { "type": "string", "minLength": 1 },
    "comments_dir": { "type": "string", "minLength": 1 },
    "report_file": { "type": "string", "minLength": 1 },
    "contract_versions": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    }
  }
}

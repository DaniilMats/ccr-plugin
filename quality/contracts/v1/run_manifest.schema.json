  "properties": {
    "contract_version": { "const": "ccr.run_manifest.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "base_dir": { "type": "string", "minLength": 1 },
    "run_dir": { "type": "string", "minLength": 1 },
    "logs_dir": { "type": "string", "minLength": 1 },
    "manifest_file": { "type": "string", "minLength": 1 },
    "status_file": { "type": "string", "minLength": 1 },
    "trace_file": { "type": "string", "minLength": 1 },
    "summary_file": { "type": "string", "minLength": 1 },
    "watch_cursor_file": { "type": "string", "minLength": 1 },
    "harness_stdout_file": { "type": "string", "minLength": 1 },
    "harness_stderr_file": { "type": "string", "minLength": 1 },
    "diff_file": { "type": "string", "minLength": 1 },
    "requirements_file": { "type": "string", "minLength": 1 },
    "mr_metadata_file": { "type": "string", "minLength": 1 },
    "route_input_file": { "type": "string", "minLength": 1 },
    "route_plan_file": { "type": "string", "minLength": 1 },
    "route_helper_err_file": { "type": "string", "minLength": 1 },
    "review_context_file": { "type": "string", "minLength": 1 },
    "static_analysis_file": { "type": "string", "minLength": 1 },
    "shuffled_diff_file": { "type": "string", "minLength": 1 },
    "requirements_prompt_pass1_file": { "type": "string", "minLength": 1 },
    "requirements_prompt_pass2_file": { "type": "string", "minLength": 1 },

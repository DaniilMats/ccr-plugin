{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRRunManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_id",
    "created_at",
    "base_dir",
    "run_dir",
    "logs_dir",
    "manifest_file",
    "status_file",
    "trace_file",
    "summary_file",
    "watch_cursor_file",
    "harness_stdout_file",
    "harness_stderr_file",
    "diff_file",
    "requirements_file",
    "mr_metadata_file",
    "route_input_file",
    "route_plan_file",
    "route_helper_err_file",
    "review_context_file",
    "static_analysis_file",
    "shuffled_diff_file",
    "requirements_prompt_pass1_file",
    "requirements_prompt_pass2_file",
    "verify_batch_dir",
    "reviewer_results_dir",
    "verifier_results_dir",
    "reviewers_file",
    "candidates_file",
    "verification_prepare_file",
    "verified_findings_file",
    "posting_approval_file",
    "posting_manifest_file",
    "posting_results_file",
    "comments_dir",
    "report_file",
    "contract_versions"

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRPostingResultV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "run_id",
    "project",
    "mr_iid",
    "started_at",
    "finished_at",
    "posted_count",
    "already_posted_count",
    "skipped_count",
    "failed_count",
    "results",
    "summary"
  ],
  "properties": {
    "contract_version": { "const": "ccr.posting_result.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "project": { "type": "string", "minLength": 1 },
    "mr_iid": { "type": ["string", "integer"] },
    "approved_all": { "type": "boolean" },
    "approved_finding_numbers": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "uniqueItems": true
    },
    "invalid_finding_numbers": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "uniqueItems": true
    },
    "started_at": { "type": "string", "minLength": 1 },
    "finished_at": { "type": "string", "minLength": 1 },
    "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
    "posted_count": { "type": "integer", "minimum": 0 },
    "already_posted_count": { "type": "integer", "minimum": 0 },
    "skipped_count": { "type": "integer", "minimum": 0 },
    "failed_count": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["finding_number", "status", "attempts"],
        "properties": {
          "finding_number": { "type": "integer", "minimum": 1 },
          "candidate_id": { "type": ["string", "null"] },
          "persona": { "type": ["string", "null"] },
          "severity": { "type": ["string", "null"], "enum": ["bug", "warning", "info", null] },
          "file": { "type": ["string", "null"] },
          "line": { "type": ["integer", "null"], "minimum": 1 },
          "message": { "type": ["string", "null"] },
          "prepared_status": { "type": ["string", "null"] },
          "fingerprint": { "type": ["string", "null"] },
          "status": {
            "enum": [
              "posted",
              "already_posted",
              "skipped_missing_anchor",
              "skipped_invalid_selection",
              "failed",
              "invalid_response"
            ]
          },
          "payload_file": { "type": ["string", "null"] },
          "response_file": { "type": ["string", "null"] },
          "discussion_id": { "type": ["string", "integer", "null"] },
          "note_id": { "type": ["string", "integer", "null"] },
          "error": { "type": ["string", "null"] },
          "attempts": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "approved_count",
        "ready_count",
        "missing_anchor_count",
        "invalid_count",
        "posted_count",
        "already_posted_count",
        "skipped_count",
        "failed_count",
        "status_counts"
      ],
      "properties": {
        "approved_all": { "type": "boolean" },
        "approved_count": { "type": "integer", "minimum": 0 },
        "ready_count": { "type": "integer", "minimum": 0 },
        "missing_anchor_count": { "type": "integer", "minimum": 0 },
        "invalid_count": { "type": "integer", "minimum": 0 },
        "ready_resolved_count": { "type": "integer", "minimum": 0 },
        "ready_resolution_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "posted_count": { "type": "integer", "minimum": 0 },
        "already_posted_count": { "type": "integer", "minimum": 0 },
        "skipped_count": { "type": "integer", "minimum": 0 },
        "failed_count": { "type": "integer", "minimum": 0 },
        "total_attempts": { "type": "integer", "minimum": 0 },
        "status_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "persona_breakdown": { "type": "object", "additionalProperties": true },
        "severity_breakdown": { "type": "object", "additionalProperties": true }
      }
    }
  }
}

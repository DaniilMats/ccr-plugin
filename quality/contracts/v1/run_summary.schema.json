{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRRunSummaryV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_version",
    "run_id",
    "mode",
    "target",
    "run_dir",
    "manifest_file",
    "status_file",
    "trace_file",
    "summary_file",
    "watch_cursor_file",
    "harness_stdout_file",
    "harness_stderr_file",
    "report_file",
    "verified_finding_count"
  ],
  "properties": {
    "contract_version": { "const": "ccr.run_summary.v1" },
    "run_id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["local", "mr", "artifact"] },
    "target": { "type": "string", "minLength": 1 },
    "project_dir": { "type": ["string", "null"] },
    "run_dir": { "type": "string", "minLength": 1 },
    "manifest_file": { "type": "string", "minLength": 1 },
    "status_file": { "type": "string", "minLength": 1 },
    "trace_file": { "type": "string", "minLength": 1 },
    "summary_file": { "type": "string", "minLength": 1 },
    "watch_cursor_file": { "type": "string", "minLength": 1 },
    "harness_stdout_file": { "type": "string", "minLength": 1 },
    "harness_stderr_file": { "type": "string", "minLength": 1 },
    "pid": { "type": ["integer", "null"], "minimum": 1 },
    "detached": { "type": ["boolean", "null"] },
    "report_file": { "type": "string", "minLength": 1 },
    "reviewers_file": { "type": "string", "minLength": 1 },
    "candidates_file": { "type": "string", "minLength": 1 },
    "verified_findings_file": { "type": "string", "minLength": 1 },
    "review_plan_summary": { "type": ["string", "null"] },
    "reviewer_worker_count": { "type": ["integer", "null"], "minimum": 0 },
    "verifier_worker_count": { "type": ["integer", "null"], "minimum": 0 },
    "reviewer_timeout_sec": { "type": ["integer", "null"], "minimum": 0 },
    "verifier_timeout_sec": { "type": ["integer", "null"], "minimum": 0 },
    "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
    "verified_finding_count": { "type": "integer", "minimum": 0 },
    "report_preview": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

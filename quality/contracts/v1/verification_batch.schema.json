{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRVerificationBatchV1",
  "type": "object",
  "additionalProperties": true,
  "required": ["contract_version", "file", "diff_hunk", "file_context", "requirements", "candidates"],
  "properties": {
    "contract_version": { "const": "ccr.verification_batch.v1" },
    "file": { "type": "string" },
    "diff_hunk": { "type": "string" },
    "file_context": { "type": "string" },
    "requirements": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "message"],
        "properties": {
          "candidate_id": { "type": "string" },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "message": { "type": "string" },
          "persona": { "type": "string" },
          "severity": { "enum": ["bug", "warning", "info"] },
          "reviewers": { "type": "array", "items": { "type": "string" } },
          "consensus": { "type": "string" },
          "symbol": { "type": ["string", "null"] },
          "anchor_status": { "enum": ["diff", "file_context", "missing", "unknown"] },
          "evidence_sources": { "type": "array", "items": { "type": "string" } },
          "source_findings": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "evidence_bundle": { "type": "object", "additionalProperties": true },
          "prefilter": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}

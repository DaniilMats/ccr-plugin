{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRVerificationResultV1",
  "type": "object",
  "additionalProperties": true,
  "required": ["contract_version", "verified_findings", "summary"],
  "properties": {
    "contract_version": { "const": "ccr.verification_result.v1" },
    "verified_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "verdict", "file", "line", "revised_message", "evidence"],
        "properties": {
          "candidate_id": { "type": "string" },
          "verdict": { "enum": ["confirmed", "uncertain", "rejected"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "revised_message": { "type": "string" },
          "title": { "type": "string" },
          "problem": { "type": "string" },
          "impact": { "type": "string" },
          "suggested_fixes": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 2
          },
          "evidence": { "type": "string" },
          "anchor_status": { "enum": ["diff", "file_context", "missing", "unknown"] },
          "evidence_sources": { "type": "array", "items": { "type": "string" } },
          "support_count": { "type": "integer", "minimum": 0 },
          "available_pass_count": { "type": "integer", "minimum": 0 },
          "prefilter_status": { "type": ["string", "null"] },
          "evidence_bundle": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "summary": { "type": "string" },
    "raw_response": { "type": "string" },
    "llm_invocation": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "provider",
        "tokens",
        "duration_ms",
        "exit_code",
        "timed_out",
        "schema_valid",
        "schema_retries"
      ],
      "properties": {
        "provider": { "type": ["string", "null"], "minLength": 1 },
        "thread_id": { "type": ["string", "null"] },
        "tokens": { "type": "integer", "minimum": 0 },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "exit_code": { "type": "integer" },
        "error": { "type": ["string", "null"] },
        "timed_out": { "type": "boolean" },
        "schema_valid": { "type": "boolean" },
        "schema_retries": { "type": "integer", "minimum": 0 },
        "schema_violations": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

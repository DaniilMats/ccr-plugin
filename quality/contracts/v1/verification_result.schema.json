{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCRVerificationResultV1",
  "type": "object",
  "additionalProperties": true,
  "required": ["contract_version", "verified_findings", "summary"],
  "properties": {
    "contract_version": { "const": "ccr.verification_result.v1" },
    "verified_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "verdict", "file", "line", "revised_message", "evidence"],
        "properties": {
          "candidate_id": { "type": "string" },
          "verdict": { "enum": ["confirmed", "uncertain", "rejected"] },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "revised_message": { "type": "string" },
          "evidence": { "type": "string" },
          "anchor_status": { "enum": ["diff", "file_context", "missing", "unknown"] },
          "evidence_sources": { "type": "array", "items": { "type": "string" } },
          "support_count": { "type": "integer", "minimum": 0 },
          "available_pass_count": { "type": "integer", "minimum": 0 },
          "prefilter_status": { "type": ["string", "null"] },
          "evidence_bundle": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "summary": { "type": "string" },
    "raw_response": { "type": "string" }
  }
}
